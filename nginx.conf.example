
worker_processes  1;

events {
    worker_connections  1024;
}

http {
    include       mime.types;
    default_type  application/octet-stream;

    sendfile        on;

    keepalive_timeout  65;

    server {
        listen       8080;
        server_name  localhost;

        location /music {
            root /Volumes/media;
            autoindex on;
            autoindex_format json;
        }

        location / {
            root /Users/lily/nginx-music-player/dist;
        }

        include servers/*;
    }
}
